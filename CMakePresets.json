{
  "version": 5,
  "configurePresets": [
    {
      "name": "release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "DBWALLER_BUILD_APPS": "ON",
        "DBWALLER_BUILD_TESTS": "OFF",
        "DBWALLER_BUILD_BENCHMARKS": "OFF"
      }
    },
    {
      "name": "release-tests",
      "inherits": "release",
      "cacheVariables": {
        "DBWALLER_BUILD_TESTS": "ON",
        "DBWALLER_BUILD_BENCHMARKS": "OFF"
      }
    },
    {
      "name": "release-benchmarks",
      "inherits": "release",
      "cacheVariables": {
        "DBWALLER_BUILD_TESTS": "OFF",
        "DBWALLER_BUILD_BENCHMARKS": "ON"
      }
    },
    {
      "name": "conan-release",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/build/Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/build/build/Release/generators/conan_toolchain.cmake",
        "DBWALLER_BUILD_APPS": "OFF",
        "DBWALLER_BUILD_TESTS": "OFF",
        "DBWALLER_BUILD_BENCHMARKS": "OFF"
      }
    },
    {
      "name": "conan-release-tests",
      "inherits": "conan-release",
      "cacheVariables": {
        "DBWALLER_BUILD_TESTS": "ON",
        "DBWALLER_BUILD_BENCHMARKS": "OFF"
      }
    },
    {
      "name": "conan-release-benchmarks",
      "inherits": "conan-release",
      "cacheVariables": {
        "DBWALLER_BUILD_TESTS": "OFF",
        "DBWALLER_BUILD_BENCHMARKS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-release",
      "configurePreset": "release"
    },
    {
      "name": "build-release-tests",
      "configurePreset": "release-tests"
    },
    {
      "name": "build-conan-release",
      "configurePreset": "conan-release"
    },
    {
      "name": "build-conan-release-tests",
      "configurePreset": "conan-release-tests"
    },
    {
      "name": "build-release-benchmarks",
      "configurePreset": "release-benchmarks"
    },
    {
      "name": "build-conan-release-benchmarks",
      "configurePreset": "conan-release-benchmarks"
    }
  ],
  "testPresets": [
    {
      "name": "tier-a-pr",
      "configurePreset": "conan-release-tests",
      "output": {
        "outputOnFailure": true
      },
      "filter": {
        "include": {
          "label": "unit|functional"
        }
      }
    },
    {
      "name": "tier-b-main",
      "configurePreset": "conan-release-tests",
      "output": {
        "outputOnFailure": true
      },
      "filter": {
        "include": {
          "label": "unit|functional|regression|system"
        }
      }
    },
    {
      "name": "tier-c-nightly",
      "configurePreset": "conan-release-tests",
      "output": {
        "outputOnFailure": true
      },
      "filter": {
        "include": {
          "label": "system|slow|nightly"
        }
      }
    }
  ]
}
